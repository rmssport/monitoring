# Managed by Ansible — do not edit manually
# Source: ansible/roles/librenms/templates/docker-compose.yml.j2

services:
  mariadb:
    image: mariadb:11
    container_name: librenms-db
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
      MYSQL_DATABASE: ${MYSQL_DATABASE:-librenms}
      MYSQL_USER: ${MYSQL_USER:-librenms}
      MYSQL_PASSWORD: ${MYSQL_PASSWORD}
      TZ: ${TZ:-{{ timezone }}}
    command:
      - mariadbd
      - --innodb-file-per-table=1
      - --lower-case-table-names=0
      - --character-set-server=utf8mb4
      - --collation-server=utf8mb4_unicode_ci
    volumes:
      - db_data:/var/lib/mysql
    networks:
      - librenms

  redis:
    image: redis:7-alpine
    container_name: librenms-redis
    restart: unless-stopped
    environment:
      TZ: ${TZ:-{{ timezone }}}
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 3
    networks:
      - librenms

  rrdcached:
    image: crazymax/rrdcached
    container_name: librenms-rrdcached
    restart: unless-stopped
    environment:
      TZ: ${TZ:-{{ timezone }}}
      LOG_LEVEL: LOG_INFO
      WRITE_TIMEOUT: 1800
      WRITE_JITTER: 1800
      WRITE_THREADS: 4
      FLUSH_DEAD_DATA_INTERVAL: 3600
    volumes:
      - librenms_rrd:/data/db
      - rrd_journal:/data/journal
    networks:
      - librenms

  librenms:
    image: librenms/librenms:latest
    container_name: librenms
    restart: unless-stopped
    depends_on:
      - mariadb
      - redis
      - rrdcached
    ports:
      - "${LIBRENMS_PORT:-8000}:8000"
    environment:
      TZ: ${TZ:-{{ timezone }}}
      PUID: 1000
      PGID: 1000
      DB_HOST: mariadb
      DB_NAME: ${MYSQL_DATABASE:-librenms}
      DB_USER: ${MYSQL_USER:-librenms}
      DB_PASSWORD: ${MYSQL_PASSWORD}
      DB_TIMEOUT: 60
      REDIS_HOST: redis
      REDIS_PORT: 6379
      RRDCACHED_SERVER: rrdcached:42217
      CACHE_DRIVER: redis
      SESSION_DRIVER: redis
      SNMP_COMMUNITY: ${SNMP_COMMUNITY:-{{ snmp_community }}}
      LIBRENMS_SNMP_COMMUNITY: ${SNMP_COMMUNITY:-{{ snmp_community }}}
      LIBRENMS_BASE_URL: ${LIBRENMS_BASE_URL:-{{ librenms_base_url }}}
      LIBRENMS_WEATHERMAP: "false"
      MEMORY_LIMIT: 256M
      UPLOAD_MAX_SIZE: 16M
    volumes:
      - librenms_data:/data
      - librenms_rrd:/data/rrd
      - {{ app_dir }}/librenms/os_detection/abus-cam.yaml:/opt/librenms/resources/definitions/os_detection/abus-cam.yaml:ro
      - {{ app_dir }}/librenms/os_discovery/abus-cam.yaml:/opt/librenms/resources/definitions/os_discovery/abus-cam.yaml:ro
    networks:
      - librenms

  dispatcher:
    image: librenms/librenms:latest
    container_name: librenms-dispatcher
    restart: unless-stopped
    depends_on:
      - librenms
    environment:
      TZ: ${TZ:-{{ timezone }}}
      PUID: 1000
      PGID: 1000
      DB_HOST: mariadb
      DB_NAME: ${MYSQL_DATABASE:-librenms}
      DB_USER: ${MYSQL_USER:-librenms}
      DB_PASSWORD: ${MYSQL_PASSWORD}
      DB_TIMEOUT: 60
      REDIS_HOST: redis
      REDIS_PORT: 6379
      RRDCACHED_SERVER: rrdcached:42217
      CACHE_DRIVER: redis
      SESSION_DRIVER: redis
      SNMP_COMMUNITY: ${SNMP_COMMUNITY:-{{ snmp_community }}}
      LIBRENMS_SNMP_COMMUNITY: ${SNMP_COMMUNITY:-{{ snmp_community }}}
      MEMORY_LIMIT: 256M
      SIDECAR_DISPATCHER: 1
    volumes:
      - librenms_data:/data
      - librenms_rrd:/data/rrd
      - {{ app_dir }}/librenms/os_detection/abus-cam.yaml:/opt/librenms/resources/definitions/os_detection/abus-cam.yaml:ro
      - {{ app_dir }}/librenms/os_discovery/abus-cam.yaml:/opt/librenms/resources/definitions/os_discovery/abus-cam.yaml:ro
    networks:
      - librenms

  syslog-ng:
    image: librenms/librenms:latest
    container_name: librenms-syslog
    restart: unless-stopped
    depends_on:
      - librenms
    ports:
      - "514:514/udp"
      - "514:514/tcp"
    environment:
      TZ: ${TZ:-{{ timezone }}}
      PUID: 1000
      PGID: 1000
      DB_HOST: mariadb
      DB_NAME: ${MYSQL_DATABASE:-librenms}
      DB_USER: ${MYSQL_USER:-librenms}
      DB_PASSWORD: ${MYSQL_PASSWORD}
      DB_TIMEOUT: 60
      REDIS_HOST: redis
      REDIS_PORT: 6379
      RRDCACHED_SERVER: rrdcached:42217
      CACHE_DRIVER: redis
      SESSION_DRIVER: redis
      MEMORY_LIMIT: 256M
      SIDECAR_SYSLOGNG: 1
    volumes:
      - librenms_data:/data
    networks:
      - librenms

  snmptrapd:
    image: librenms/librenms:latest
    container_name: librenms-snmptrapd
    restart: unless-stopped
    depends_on:
      - librenms
    ports:
      - "162:162/udp"
    environment:
      TZ: ${TZ:-{{ timezone }}}
      PUID: 1000
      PGID: 1000
      DB_HOST: mariadb
      DB_NAME: ${MYSQL_DATABASE:-librenms}
      DB_USER: ${MYSQL_USER:-librenms}
      DB_PASSWORD: ${MYSQL_PASSWORD}
      DB_TIMEOUT: 60
      REDIS_HOST: redis
      REDIS_PORT: 6379
      RRDCACHED_SERVER: rrdcached:42217
      CACHE_DRIVER: redis
      SESSION_DRIVER: redis
      MEMORY_LIMIT: 256M
      SIDECAR_SNMPTRAPD: 1
    volumes:
      - librenms_data:/data
    networks:
      - librenms

volumes:
  db_data:
  librenms_data:
  librenms_rrd:
  rrd_journal:

networks:
  librenms:
    driver: bridge
