# LibreNMS Docker Compose environment variables
# Copy this to .env and fill in the values:
#   cp .env.example .env

# Timezone
TZ=Europe/Copenhagen

# Database
MYSQL_ROOT_PASSWORD=changeme-root-password
MYSQL_DATABASE=librenms
MYSQL_USER=librenms
MYSQL_PASSWORD=changeme-librenms-password

# LibreNMS
LIBRENMS_PORT=8000
LIBRENMS_BASE_URL=http://10.7.5.100:8000

# SNMP
SNMP_COMMUNITY=public
